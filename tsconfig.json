{
    "compilerOptions": {
        "target": "es2020",
        "module": "Node16",
        "moduleResolution": "node16",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "outDir": "dist",
        "jsx": "react",
        "jsxFactory": "JSX.createElement",
        "jsxFragmentFactory": "JSX.Fragment",
        "skipLibCheck": true
    },
    "include": ["src"]
}
